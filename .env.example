# Groq (server-side only — copy to `.env.local`; never commit secrets)
# Leave blank until you have a key; the app falls back to mock fixtures automatically.
GROQ_API_KEY=
# Example: llama-3.3-70b-versatile — pick a current model in the Groq console
GROQ_MODEL=

# Force fixture/mock pipeline even when GROQ_API_KEY is set (optional dev flag)
# LLM_FORCE_MOCK=true

# Optional later (PDF pipeline)
# PDF_ENGINE=playwright
